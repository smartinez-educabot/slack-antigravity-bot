# ============================================
# Slack Bot Configuration
# ============================================
# Obtené estos valores desde https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# ============================================
# Google OAuth (para Antigravity Cloud Code)
# ============================================
# Creá un OAuth Client en Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Tipo: Web Application
# Redirect URI: https://tu-app.vercel.app/api/auth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://tu-app.vercel.app/api/auth/callback

# Estos se llenan automáticamente después del flujo OAuth
# (o los podés extraer manualmente desde Antigravity)
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# ============================================
# Antigravity Cloud Code Config
# ============================================
# Modelo a usar: gemini-3-pro, gemini-3-flash, claude-sonnet-4-6, etc.
ANTIGRAVITY_MODEL=gemini-3-pro
# Project ID (el default de Antigravity)
ANTIGRAVITY_PROJECT_ID=rising-fact-p41fc

# ============================================
# Opcional: System Prompt para tu agente
# ============================================
AGENT_SYSTEM_PROMPT=Sos un asistente útil que responde en español. Respondé de forma concisa y clara.
